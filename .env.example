# HiveMQ Cloud MQTT broker credentials
HIVEMQ_HOST=your-cluster.s1.eu.hivemq.cloud
HIVEMQ_USER=your-hivemq-username
HIVEMQ_PASS=your-hivemq-password

# Neon PostgreSQL connection strings
# Use DATABASE_URL (direct) for drizzle-kit migrations only
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Use DATABASE_POOLER_URL for all application queries
DATABASE_POOLER_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require

# Camera HLS stream URLs (optional, web package only - Vite build-time substitution)
# If omitted, CameraSection tabs won't render (graceful degradation)
VITE_CAMERA_WEBCAM_URL=http://your-mediamtx-host:8888/webcam/index.m3u8
VITE_CAMERA_PI_URL=http://your-mediamtx-host:8888/picamera/index.m3u8
